alias cp="cp -i"
alias df='df -h'
alias free='free -m'
alias more=less
alias ls="ls --group-directories-first"
alias la="ls --group-directories-first -a"
alias please="sudo"
alias ::="TMP=\$PREV && PREV=\$(pwd) && cd \$TMP && TMP=\"\""
alias ..="PREV=\$(pwd) && cd .."
alias ...="PREV=\$(pwd) && cd ../.."
alias cd="PREV=\$(pwd) && cd"
